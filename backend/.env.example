NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/maktab_crm?schema=public

JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ISSUER=maktab-crm
JWT_AUDIENCE=maktab-crm-users
ACCESS_EXPIRES=15m
REFRESH_EXPIRES=7d

CORS_ORIGINS=http://localhost:5173
TRUST_PROXY=0

ENABLE_AUTO_CLASS_PROMOTION=false
ENABLE_AUTO_PAYROLL=false
AUTO_PAYROLL_INTERVAL_MINUTES=60
AUTO_PAYROLL_AUTO_APPROVE=true
AUTO_PAYROLL_AUTO_PAY=false
AUTO_PAYROLL_PAYMENT_METHOD=BANK

ENABLE_AUTO_FINANCE=false
AUTO_FINANCE_INTERVAL_MINUTES=60
AUTO_FINANCE_SYNC_FUTURE_MONTHS=3

ENABLE_REFRESH_SESSION_CLEANUP=true
REFRESH_SESSION_CLEANUP_INTERVAL_MINUTES=360
REFRESH_SESSION_REVOKED_RETENTION_DAYS=30

MANAGER_SCOPE_ENFORCED=true
ALLOW_LEGACY_PLAIN_CREDENTIAL_RESPONSE=false
RATE_LIMIT_STORE=auto
LOGIN_RATE_LIMIT_WINDOW_MINUTES=10
LOGIN_RATE_LIMIT_MAX=12
REFRESH_RATE_LIMIT_WINDOW_MINUTES=10
REFRESH_RATE_LIMIT_MAX=40
RATE_LIMIT_DB_CLEANUP_EVERY=100
RATE_LIMIT_DB_RETENTION_HOURS=24
MONITORING_TOKEN=replace-with-a-long-random-monitoring-token

LOG_LEVEL=debug
HTTP_ACCESS_LOGS=true
SLOW_REQUEST_WARN_MS=1500
