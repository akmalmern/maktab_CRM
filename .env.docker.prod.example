POSTGRES_DB=maktab_crm
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password

JWT_ACCESS_SECRET=replace-with-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
ACCESS_EXPIRES=15m
REFRESH_EXPIRES=7d

FRONTEND_PORT=8080
BACKEND_PORT=5000
CORS_ORIGINS=http://localhost:8080
TRUST_PROXY=1
RATE_LIMIT_STORE=db
LOGIN_RATE_LIMIT_WINDOW_MINUTES=10
LOGIN_RATE_LIMIT_MAX=12
REFRESH_RATE_LIMIT_WINDOW_MINUTES=10
REFRESH_RATE_LIMIT_MAX=40
RATE_LIMIT_DB_CLEANUP_EVERY=100
RATE_LIMIT_DB_RETENTION_HOURS=24
MONITORING_TOKEN=replace-with-long-random-monitoring-token
LOG_LEVEL=info
HTTP_ACCESS_LOGS=true
SLOW_REQUEST_WARN_MS=1500

ENABLE_AUTO_CLASS_PROMOTION=false
ENABLE_AUTO_PAYROLL=false
ENABLE_AUTO_FINANCE=false
ENABLE_REFRESH_SESSION_CLEANUP=true
MANAGER_SCOPE_ENFORCED=true
