POSTGRES_DB=maktab_crm
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

BACKEND_PORT=5000
FRONTEND_PORT=5173

JWT_ACCESS_SECRET=change-this-access-secret-in-real-usage
JWT_REFRESH_SECRET=change-this-refresh-secret-in-real-usage
ACCESS_EXPIRES=15m
REFRESH_EXPIRES=7d
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TRUST_PROXY=0

ENABLE_AUTO_CLASS_PROMOTION=false
ENABLE_AUTO_PAYROLL=false
ENABLE_AUTO_FINANCE=false
ENABLE_REFRESH_SESSION_CLEANUP=true
MANAGER_SCOPE_ENFORCED=true

VITE_API_URL=
VITE_PROXY_TARGET=http://backend:5000
CHOKIDAR_USEPOLLING=true
